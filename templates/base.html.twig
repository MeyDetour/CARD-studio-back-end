<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}CARD Studio{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
        <link rel="stylesheet" href="/assets/styles/documentation.css">
     {% block stylesheets %}
        {{ importmap('app') }}
        
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/documentation.css') }}">
    {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}


        <script>
        window.addEventListener("DOMContentLoaded", () => {
    

    document.querySelectorAll(".json-content").forEach((elt) => {
        let rawContent = elt.textContent.trim();

        // Remplace les guillemets simples par des guillemets doubles
        rawContent = rawContent.replace(/'/g, '"');

        try {
            const parsedJson = JSON.parse(rawContent);
            elt.textContent = JSON.stringify(parsedJson, null, 2); // Formate le JSON
        } catch (error) {
            console.error("Erreur après remplacement des guillemets :", rawContent, error);
        }
    });
    document.querySelectorAll("pre").forEach((pre) => {

        let types = [
            ["int", "intColor"],
            ["boolean", "booleanColor"],
            ["string", "stringColor"],
            ["url", "urlColor"],
            ["NOT NULL", "notnullColor"],
            ["NULL", "notnullColor"],
            ["datetime", "datetimeColor"],
        ]

        let res = pre.innerHTML
        types.forEach((type) => {
            res = res.replaceAll(type[0], `<span class='${type[1]}'>${type[0]}</span>`)
        })


        pre.innerHTML = res
    })
})
        </script>
    </body>
</html>
